{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threadmill.dev/protocol/threadmill-rpc.schema.json",
  "title": "Threadmill RPC Protocol",
  "description": "JSON-RPC 2.0 protocol between Threadmill (macOS app) and Spindle (beast daemon). Text frames carry JSON-RPC. Binary frames carry terminal I/O with a 2-byte channel ID prefix.",
  "version": "0.1.0",

  "$defs": {
    "JsonRpcRequest": {
      "type": "object",
      "required": ["jsonrpc", "method"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "type": ["integer", "string", "null"], "description": "Present for requests, absent for notifications" },
        "method": { "type": "string" },
        "params": {}
      }
    },

    "JsonRpcResponse": {
      "type": "object",
      "required": ["jsonrpc", "id"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "type": ["integer", "string", "null"] },
        "result": {},
        "error": { "$ref": "#/$defs/JsonRpcError" }
      }
    },

    "JsonRpcError": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "integer" },
        "message": { "type": "string" }
      }
    },

    "BinaryFrame": {
      "description": "Binary WebSocket frame: [u16be channel_id][raw terminal bytes]. Channel ID assigned by terminal.attach response.",
      "type": "object",
      "properties": {
        "channel_id": { "type": "integer", "minimum": 1, "maximum": 65535, "description": "First 2 bytes, big-endian u16" },
        "data": { "type": "string", "contentEncoding": "binary", "description": "Remaining bytes: raw terminal I/O" }
      }
    },

    "Project": {
      "type": "object",
      "required": ["id", "name", "path", "default_branch", "presets"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "path": { "type": "string", "description": "Absolute path on beast" },
        "default_branch": { "type": "string" },
        "presets": {
          "type": "array",
          "items": { "$ref": "#/$defs/PresetConfig" }
        }
      }
    },

    "PresetConfig": {
      "type": "object",
      "required": ["name", "command"],
      "properties": {
        "name": { "type": "string" },
        "command": { "type": "string" },
        "cwd": { "type": ["string", "null"] }
      }
    },

    "Thread": {
      "type": "object",
      "required": ["id", "project_id", "name", "branch", "worktree_path", "status", "source_type", "created_at", "tmux_session"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "project_id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "branch": { "type": "string" },
        "worktree_path": { "type": "string" },
        "status": { "$ref": "#/$defs/ThreadStatus" },
        "source_type": { "$ref": "#/$defs/SourceType" },
        "created_at": { "type": "string", "format": "date-time" },
        "tmux_session": { "type": "string" }
      }
    },

    "ThreadStatus": {
      "type": "string",
      "enum": ["creating", "active", "closing", "closed", "hidden", "failed"]
    },

    "SourceType": {
      "type": "string",
      "enum": ["new_feature", "existing_branch", "pull_request"]
    },

    "PresetStatus": {
      "type": "string",
      "enum": ["running", "stopped", "crashed"]
    },

    "StateVersion": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonic daemon state version"
    },

    "ThreadProgress": {
      "type": "object",
      "required": ["thread_id", "step"],
      "properties": {
        "thread_id": { "type": "string", "format": "uuid" },
        "step": {
          "type": "string",
          "enum": ["fetching", "creating_worktree", "copying_files", "running_hooks", "starting_presets", "ready"]
        },
        "message": { "type": "string" },
        "error": { "type": ["string", "null"] }
      }
    },

    "ThreadStatusChanged": {
      "type": "object",
      "required": ["thread_id", "old", "new"],
      "properties": {
        "thread_id": { "type": "string", "format": "uuid" },
        "old": { "$ref": "#/$defs/ThreadStatus" },
        "new": { "$ref": "#/$defs/ThreadStatus" }
      }
    },

    "PresetProcessEvent": {
      "type": "object",
      "required": ["thread_id", "preset", "event"],
      "properties": {
        "thread_id": { "type": "string", "format": "uuid" },
        "preset": { "type": "string" },
        "event": { "type": "string", "enum": ["started", "exited", "crashed"] },
        "exit_code": { "type": ["integer", "null"] }
      }
    },

    "StateSnapshot": {
      "type": "object",
      "required": ["state_version", "projects", "threads"],
      "properties": {
        "state_version": { "$ref": "#/$defs/StateVersion" },
        "projects": {
          "type": "array",
          "items": { "$ref": "#/$defs/Project" }
        },
        "threads": {
          "type": "array",
          "items": { "$ref": "#/$defs/Thread" }
        }
      }
    },

    "StateDeltaChange": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "project"],
          "properties": {
            "type": { "const": "project.added" },
            "project": { "$ref": "#/$defs/Project" }
          }
        },
        {
          "type": "object",
          "required": ["type", "project_id"],
          "properties": {
            "type": { "const": "project.removed" },
            "project_id": { "type": "string", "format": "uuid" }
          }
        },
        {
          "type": "object",
          "required": ["type", "thread"],
          "properties": {
            "type": { "const": "thread.created" },
            "thread": { "$ref": "#/$defs/Thread" }
          }
        },
        {
          "type": "object",
          "required": ["type", "thread_id"],
          "properties": {
            "type": { "const": "thread.removed" },
            "thread_id": { "type": "string", "format": "uuid" }
          }
        },
        {
          "type": "object",
          "required": ["type", "thread_id", "old", "new"],
          "properties": {
            "type": { "const": "thread.status_changed" },
            "thread_id": { "type": "string", "format": "uuid" },
            "old": { "$ref": "#/$defs/ThreadStatus" },
            "new": { "$ref": "#/$defs/ThreadStatus" }
          }
        },
        {
          "type": "object",
          "required": ["type", "thread_id", "preset", "event"],
          "properties": {
            "type": { "const": "preset.process_event" },
            "thread_id": { "type": "string", "format": "uuid" },
            "preset": { "type": "string" },
            "event": { "type": "string", "enum": ["started", "exited", "crashed"] },
            "exit_code": { "type": ["integer", "null"] }
          }
        }
      ]
    },

    "DirectoryEntry": {
      "type": "object",
      "required": ["name", "is_dir"],
      "properties": {
        "name": { "type": "string" },
        "is_dir": { "type": "boolean" },
        "is_git_repo": { "type": "boolean" }
      }
    }
  },

  "methods": {
    "ping": {
      "description": "Health check",
      "params": null,
      "result": { "const": "pong" }
    },

    "state.snapshot": {
      "description": "Fetch full authoritative daemon state with a monotonic version",
      "params": null,
      "result": { "$ref": "#/$defs/StateSnapshot" }
    },

    "project.list": {
      "description": "List all registered projects",
      "params": null,
      "result": {
        "type": "array",
        "items": { "$ref": "#/$defs/Project" }
      }
    },

    "project.add": {
      "description": "Register an existing repo as a project",
      "params": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string", "description": "Absolute path to a git repository on beast (the remote machine), not your local Mac" }
        }
      },
      "result": { "$ref": "#/$defs/Project" }
    },

    "project.clone": {
      "description": "Clone a repository on beast and register it as a project",
      "params": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string" },
          "path": { "type": "string", "description": "Optional absolute destination path (or parent directory) on beast. If omitted, clone goes to /home/wsl/dev/<repo-name>." }
        }
      },
      "result": { "$ref": "#/$defs/Project" }
    },

    "project.remove": {
      "description": "Unregister a project (does not delete files)",
      "params": {
        "type": "object",
        "required": ["project_id"],
        "properties": {
          "project_id": { "type": "string", "format": "uuid" }
        }
      },
      "result": { "type": "object", "properties": { "removed": { "type": "boolean" } } }
    },

    "project.branches": {
      "description": "List remote branches for a project",
      "params": {
        "type": "object",
        "required": ["project_id"],
        "properties": {
          "project_id": { "type": "string", "format": "uuid" }
        }
      },
      "result": {
        "type": "array",
        "items": { "type": "string" }
      }
    },

    "project.browse": {
      "description": "List directory contents on beast (for project picker UI)",
      "params": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": { "type": "string" }
        }
      },
      "result": {
        "type": "array",
        "items": { "$ref": "#/$defs/DirectoryEntry" }
      }
    },

    "thread.create": {
      "description": "Create a new thread (worktree + tmux session). Returns immediately with thread ID. Progress streamed via thread.progress events.",
      "params": {
        "type": "object",
        "required": ["project_id", "name", "source_type"],
        "properties": {
          "project_id": { "type": "string", "format": "uuid" },
          "name": { "type": "string", "description": "Thread/branch name" },
          "source_type": { "$ref": "#/$defs/SourceType" },
          "branch": { "type": "string", "description": "Branch name for existing_branch/pull_request source types" }
        }
      },
      "result": { "$ref": "#/$defs/Thread" }
    },

    "thread.close": {
      "description": "Close or hide a thread",
      "params": {
        "type": "object",
        "required": ["thread_id", "mode"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "mode": { "type": "string", "enum": ["close", "hide"] }
        }
      },
      "result": { "type": "object", "properties": { "status": { "$ref": "#/$defs/ThreadStatus" } } }
    },

    "thread.reopen": {
      "description": "Reopen a hidden thread",
      "params": {
        "type": "object",
        "required": ["thread_id"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" }
        }
      },
      "result": { "$ref": "#/$defs/Thread" }
    },

    "thread.hide": {
      "description": "Hide a thread without deleting its worktree",
      "params": {
        "type": "object",
        "required": ["thread_id"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" }
        }
      },
      "result": { "type": "object", "required": ["status"], "properties": { "status": { "$ref": "#/$defs/ThreadStatus" } } }
    },

    "thread.list": {
      "description": "List threads, optionally filtered by project",
      "params": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string", "format": "uuid", "description": "Optional filter" }
        }
      },
      "result": {
        "type": "array",
        "items": { "$ref": "#/$defs/Thread" }
      }
    },

    "terminal.attach": {
      "description": "Attach to a tmux pane and start relaying I/O as binary frames",
      "params": {
        "type": "object",
        "required": ["thread_id", "preset"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "preset": { "type": "string" }
        }
      },
      "result": {
        "type": "object",
        "required": ["channel_id"],
        "properties": {
          "channel_id": { "type": "integer", "minimum": 1, "maximum": 65535 }
        }
      }
    },

    "terminal.detach": {
      "description": "Stop relaying a tmux pane",
      "params": {
        "type": "object",
        "required": ["thread_id", "preset"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "preset": { "type": "string" }
        }
      },
      "result": { "type": "object", "properties": { "detached": { "type": "boolean" } } }
    },

    "terminal.resize": {
      "description": "Resize an attached tmux pane",
      "params": {
        "type": "object",
        "required": ["thread_id", "preset", "cols", "rows"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "preset": { "type": "string" },
          "cols": { "type": "integer", "minimum": 1 },
          "rows": { "type": "integer", "minimum": 1 }
        }
      },
      "result": { "type": "object", "properties": { "resized": { "type": "boolean" } } }
    },

    "preset.start": {
      "description": "Start a preset for a thread",
      "params": {
        "type": "object",
        "required": ["thread_id", "preset"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "preset": { "type": "string" }
        }
      },
      "result": { "type": "object", "required": ["ok"], "properties": { "ok": { "type": "boolean" } } }
    },

    "preset.stop": {
      "description": "Stop a preset for a thread",
      "params": {
        "type": "object",
        "required": ["thread_id", "preset"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "preset": { "type": "string" }
        }
      },
      "result": { "type": "object", "required": ["ok"], "properties": { "ok": { "type": "boolean" } } }
    },

    "preset.restart": {
      "description": "Restart a preset for a thread",
      "params": {
        "type": "object",
        "required": ["thread_id", "preset"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" },
          "preset": { "type": "string" }
        }
      },
      "result": { "type": "object", "required": ["ok"], "properties": { "ok": { "type": "boolean" } } }
    }
  },

  "events": {
    "thread.progress": {
      "description": "Streamed during thread.create",
      "params": { "$ref": "#/$defs/ThreadProgress" }
    },

    "thread.status_changed": {
      "description": "Thread status transition",
      "params": { "$ref": "#/$defs/ThreadStatusChanged" }
    },

    "preset.process_event": {
      "description": "Preset process lifecycle event",
      "params": { "$ref": "#/$defs/PresetProcessEvent" }
    },

    "project.added": {
      "description": "A project was added",
      "params": {
        "type": "object",
        "required": ["project"],
        "properties": {
          "project": { "$ref": "#/$defs/Project" }
        }
      }
    },

    "project.removed": {
      "description": "A project was removed",
      "params": {
        "type": "object",
        "required": ["project_id"],
        "properties": {
          "project_id": { "type": "string", "format": "uuid" }
        }
      }
    },

    "thread.created": {
      "description": "A thread was created",
      "params": {
        "type": "object",
        "required": ["thread"],
        "properties": {
          "thread": { "$ref": "#/$defs/Thread" }
        }
      }
    },

    "thread.removed": {
      "description": "A thread was removed",
      "params": {
        "type": "object",
        "required": ["thread_id"],
        "properties": {
          "thread_id": { "type": "string", "format": "uuid" }
        }
      }
    },

    "state.delta": {
      "description": "Ordered state delta; clients re-fetch snapshot if a version gap is detected",
      "params": {
        "type": "object",
        "required": ["state_version", "changes"],
        "properties": {
          "state_version": { "$ref": "#/$defs/StateVersion" },
          "changes": {
            "type": "array",
            "items": { "$ref": "#/$defs/StateDeltaChange" }
          }
        }
      }
  }
}
}
