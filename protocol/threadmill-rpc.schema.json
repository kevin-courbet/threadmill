{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://threadmill.dev/protocol/threadmill-rpc.schema.json",
  "title": "Threadmill RPC Protocol",
  "description": "JSON-RPC 2.0 protocol between Threadmill (macOS app) and Spindle (daemon). This schema covers text (JSON) frames only. Binary frames (terminal I/O) use a raw wire format documented in docs/agents/communication-protocol.md.",
  "version": "0.2.0",
  "$defs": {
    "EmptyParams": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "maxProperties": 0
        }
      ]
    },
    "JsonRpcRequest": {
      "type": "object",
      "required": [
        "jsonrpc",
        "method"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "type": [
            "integer",
            "string",
            "null"
          ],
          "description": "Present for requests, absent for notifications"
        },
        "method": {
          "type": "string"
        },
        "params": {}
      }
    },
    "JsonRpcError": {
      "type": "object",
      "required": [
        "code",
        "message"
      ],
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string"
        },
        "data": {
          "$ref": "#/$defs/RpcErrorData"
        }
      }
    },
    "RpcErrorData": {
      "type": "object",
      "properties": {
        "kind": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "JsonRpcResponse": {
      "type": "object",
      "required": [
        "jsonrpc",
        "id"
      ],
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "type": [
            "integer",
            "string",
            "null"
          ]
        },
        "result": {},
        "error": {
          "$ref": "#/$defs/JsonRpcError"
        }
      }
    },
    "PresetConfig": {
      "type": "object",
      "required": [
        "name",
        "command"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "cwd": {
          "type": "string"
        }
      }
    },
    "Project": {
      "type": "object",
      "required": [
        "id",
        "name",
        "path",
        "default_branch",
        "presets"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "description": "Absolute path on beast"
        },
        "default_branch": {
          "type": "string"
        },
        "presets": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PresetConfig"
          }
        }
      }
    },
    "SourceType": {
      "type": "string",
      "enum": [
        "new_feature",
        "existing_branch",
        "pull_request",
        "main_checkout"
      ]
    },
    "ThreadStatus": {
      "type": "string",
      "enum": [
        "creating",
        "active",
        "closing",
        "closed",
        "hidden",
        "failed"
      ]
    },
    "Thread": {
      "type": "object",
      "required": [
        "id",
        "project_id",
        "name",
        "branch",
        "worktree_path",
        "status",
        "source_type",
        "created_at",
        "tmux_session",
        "port_offset"
      ],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "project_id": {
          "type": "string",
          "format": "uuid"
        },
        "name": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "worktree_path": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ThreadStatus"
        },
        "source_type": {
          "$ref": "#/$defs/SourceType"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "tmux_session": {
          "type": "string"
        },
        "port_offset": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535
        }
      }
    },
    "ThreadProgressStep": {
      "type": "string",
      "enum": [
        "fetching",
        "creating_worktree",
        "copying_files",
        "running_hooks",
        "starting_presets",
        "ready"
      ]
    },
    "ThreadProgress": {
      "type": "object",
      "required": [
        "thread_id",
        "step"
      ],
      "properties": {
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "step": {
          "$ref": "#/$defs/ThreadProgressStep"
        },
        "message": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      }
    },
    "ThreadStatusChanged": {
      "type": "object",
      "required": [
        "thread_id",
        "old",
        "new"
      ],
      "properties": {
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "old": {
          "$ref": "#/$defs/ThreadStatus"
        },
        "new": {
          "$ref": "#/$defs/ThreadStatus"
        }
      }
    },
    "PresetProcessEvent": {
      "type": "object",
      "required": [
        "thread_id",
        "preset",
        "event"
      ],
      "properties": {
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "preset": {
          "type": "string"
        },
        "event": {
          "type": "string",
          "enum": [
            "started",
            "exited",
            "crashed"
          ]
        },
        "exit_code": {
          "type": "integer"
        },
        "crash_context": {
          "$ref": "#/$defs/PresetCrashContext"
        }
      }
    },
    "PresetCrashContext": {
      "type": "object",
      "properties": {
        "signal": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "last_output": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "PresetOutputEvent": {
      "type": "object",
      "required": [
        "thread_id",
        "preset",
        "stream",
        "chunk"
      ],
      "properties": {
        "thread_id": {
          "type": "string",
          "format": "uuid"
        },
        "preset": {
          "type": "string"
        },
        "stream": {
          "type": "string",
          "enum": [
            "stdout",
            "stderr"
          ]
        },
        "chunk": {
          "type": "string"
        }
      }
    },
    "StateVersion": {
      "type": "integer",
      "minimum": 0,
      "description": "Monotonic daemon state version"
    },
    "StateSnapshot": {
      "type": "object",
      "required": [
        "state_version",
        "projects",
        "threads"
      ],
      "properties": {
        "state_version": {
          "$ref": "#/$defs/StateVersion"
        },
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Project"
          }
        },
        "threads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Thread"
          }
        }
      }
    },
    "SessionHelloParams": {
      "type": "object",
      "required": [
        "client",
        "protocol_version",
        "capabilities"
      ],
      "properties": {
        "client": {
          "type": "object",
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string"
            },
            "version": {
              "type": "string"
            }
          }
        },
        "protocol_version": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "SessionHelloResult": {
      "type": "object",
      "required": [
        "session_id",
        "protocol_version",
        "capabilities",
        "state_version"
      ],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "protocol_version": {
          "type": "string"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "state_version": {
          "$ref": "#/$defs/StateVersion"
        }
      }
    },
    "SystemStatsResult": {
      "type": "object",
      "required": [
        "load_avg_1m",
        "memory_total_mb",
        "memory_used_mb",
        "opencode_instances"
      ],
      "properties": {
        "load_avg_1m": {
          "type": "number"
        },
        "memory_total_mb": {
          "type": "integer",
          "minimum": 0
        },
        "memory_used_mb": {
          "type": "integer",
          "minimum": 0
        },
        "opencode_instances": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "OpencodeStatusResult": {
      "type": "object",
      "required": [
        "running",
        "port",
        "url"
      ],
      "properties": {
        "running": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "url": {
          "type": "string"
        }
      }
    },
    "StateDeltaOperation": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "project"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "project.added"
            },
            "project": {
              "$ref": "#/$defs/Project"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "project_id"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "project.removed"
            },
            "project_id": {
              "type": "string",
              "format": "uuid"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "thread"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "thread.created"
            },
            "thread": {
              "$ref": "#/$defs/Thread"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "thread_id"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "thread.removed"
            },
            "thread_id": {
              "type": "string",
              "format": "uuid"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "thread_id",
            "old",
            "new"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "thread.status_changed"
            },
            "thread_id": {
              "type": "string",
              "format": "uuid"
            },
            "old": {
              "$ref": "#/$defs/ThreadStatus"
            },
            "new": {
              "$ref": "#/$defs/ThreadStatus"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "thread_id",
            "preset",
            "event"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "preset.process_event"
            },
            "thread_id": {
              "type": "string",
              "format": "uuid"
            },
            "preset": {
              "type": "string"
            },
            "event": {
              "type": "string",
              "enum": [
                "started",
                "exited",
                "crashed"
              ]
            },
            "exit_code": {
              "type": "integer"
            },
            "crash_context": {
              "$ref": "#/$defs/PresetCrashContext"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "op_id",
            "type",
            "thread_id",
            "preset",
            "stream",
            "chunk"
          ],
          "properties": {
            "op_id": {
              "type": "string"
            },
            "type": {
              "const": "preset.output"
            },
            "thread_id": {
              "type": "string",
              "format": "uuid"
            },
            "preset": {
              "type": "string"
            },
            "stream": {
              "type": "string",
              "enum": [
                "stdout",
                "stderr"
              ]
            },
            "chunk": {
              "type": "string"
            }
          }
        }
      ]
    },
    "DirectoryEntry": {
      "type": "object",
      "required": [
        "name",
        "is_dir"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "is_dir": {
          "type": "boolean"
        },
        "is_git_repo": {
          "type": "boolean"
        }
      }
    },
    "FileEntry": {
      "type": "object",
      "required": [
        "name",
        "path",
        "isDirectory",
        "size"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "isDirectory": {
          "type": "boolean"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "FileListResult": {
      "type": "object",
      "required": [
        "entries"
      ],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/FileEntry"
          }
        }
      }
    },
    "FileReadResult": {
      "type": "object",
      "required": [
        "content",
        "size"
      ],
      "properties": {
        "content": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "FileGitStatus": {
      "type": "string",
      "enum": [
        "modified",
        "staged",
        "added",
        "untracked",
        "deleted",
        "renamed",
        "conflicted"
      ]
    },
    "FileGitStatusResult": {
      "type": "object",
      "required": [
        "entries"
      ],
      "properties": {
        "entries": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/FileGitStatus"
          }
        }
      }
    }
  },
  "methods": {
    "session.hello": {
      "description": "Negotiate protocol session and capabilities",
      "params": {
        "$ref": "#/$defs/SessionHelloParams"
      },
      "result": {
        "$ref": "#/$defs/SessionHelloResult"
      }
    },
    "ping": {
      "description": "Health check",
      "params": {
        "$ref": "#/$defs/EmptyParams"
      },
      "result": {
        "const": "pong"
      }
    },
    "system.stats": {
      "description": "Read daemon host load, memory, and opencode process counts",
      "params": {
        "$ref": "#/$defs/EmptyParams"
      },
      "result": {
        "$ref": "#/$defs/SystemStatsResult"
      }
    },
    "state.snapshot": {
      "description": "Fetch full daemon state",
      "params": {
        "$ref": "#/$defs/EmptyParams"
      },
      "result": {
        "$ref": "#/$defs/StateSnapshot"
      }
    },
    "opencode.status": {
      "description": "Check shared opencode serve status",
      "params": {
        "$ref": "#/$defs/EmptyParams"
      },
      "result": {
        "$ref": "#/$defs/OpencodeStatusResult"
      }
    },
    "opencode.ensure": {
      "description": "Ensure shared opencode serve is running",
      "params": {
        "$ref": "#/$defs/EmptyParams"
      },
      "result": {
        "$ref": "#/$defs/OpencodeStatusResult"
      }
    },
    "project.list": {
      "description": "List projects",
      "params": {
        "$ref": "#/$defs/EmptyParams"
      },
      "result": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/Project"
        }
      }
    },
    "project.add": {
      "description": "Register existing repository as project",
      "params": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "result": {
        "$ref": "#/$defs/Project"
      }
    },
    "project.clone": {
      "description": "Clone repository on beast and register project",
      "params": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          },
          "path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "result": {
        "$ref": "#/$defs/Project"
      }
    },
    "project.remove": {
      "description": "Unregister project",
      "params": {
        "type": "object",
        "required": [
          "project_id"
        ],
        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "result": {
        "type": "object",
        "properties": {
          "removed": {
            "type": "boolean"
          }
        }
      }
    },
    "project.branches": {
      "description": "List project remote branches",
      "params": {
        "type": "object",
        "required": [
          "project_id"
        ],
        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "result": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "project.browse": {
      "description": "List directory entries on beast",
      "params": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "result": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/DirectoryEntry"
        }
      }
    },
    "file.list": {
      "description": "List files and directories within an allowed root",
      "params": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "result": {
        "$ref": "#/$defs/FileListResult"
      }
    },
    "file.read": {
      "description": "Read UTF-8 text file contents within an allowed root",
      "params": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "result": {
        "$ref": "#/$defs/FileReadResult"
      }
    },
    "file.git_status": {
      "description": "Read git status for a known worktree root",
      "params": {
        "type": "object",
        "required": [
          "path"
        ],
        "properties": {
          "path": {
            "type": "string"
          }
        }
      },
      "result": {
        "$ref": "#/$defs/FileGitStatusResult"
      }
    },
    "thread.create": {
      "description": "Create thread (worktree + tmux) and return immediately",
      "params": {
        "type": "object",
        "required": [
          "project_id",
          "name",
          "source_type"
        ],
        "properties": {
          "project_id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "source_type": {
            "$ref": "#/$defs/SourceType"
          },
          "branch": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "result": {
        "$ref": "#/$defs/Thread"
      }
    },
    "thread.list": {
      "description": "List threads, optionally filtered by project",
      "params": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "properties": {
              "project_id": {
                "type": "string",
                "format": "uuid"
              }
            }
          }
        ]
      },
      "result": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/Thread"
        }
      }
    },
    "thread.close": {
      "description": "Close or hide thread depending on mode",
      "params": {
        "type": "object",
        "required": [
          "thread_id",
          "mode"
        ],
        "properties": {
          "thread_id": {
            "type": "string",
            "format": "uuid"
          },
          "mode": {
            "type": "string",
            "enum": [
              "close",
              "hide"
            ]
          }
        }
      },
      "result": {
        "type": "object",
        "properties": {
          "status": {
            "$ref": "#/$defs/ThreadStatus"
          }
        }
      }
    },
    "thread.reopen": {
      "description": "Reopen hidden thread",
      "params": {
        "type": "object",
        "required": [
          "thread_id"
        ],
        "properties": {
          "thread_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "result": {
        "$ref": "#/$defs/Thread"
      }
    },
    "thread.hide": {
      "description": "Hide thread",
      "params": {
        "type": "object",
        "required": [
          "thread_id"
        ],
        "properties": {
          "thread_id": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "result": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "$ref": "#/$defs/ThreadStatus"
          }
        }
      }
    },
    "terminal.attach": {
      "description": "Attach preset pane and allocate terminal channel",
      "params": {
        "type": "object",
        "required": [
          "thread_id",
          "preset"
        ],
        "properties": {
          "thread_id": {
            "type": "string",
